	<JavaClasses>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1777009049474</Id>
			<Name><![CDATA[APIConnector]]></Name>
			<Text><![CDATA[import java.io.*;
import java.net.*;

public class APIConnector {

    public static double callAPI(
        double demand,
        double interest,
        double supply,
        double growth,
        double economy
    ) {
        try {
            String url = "http://127.0.0.1:5000/api/simulation/predict";

            String json = "{"
                + "\"demand\":" + demand + ","
                + "\"interest\":" + interest + ","
                + "\"supply\":" + supply + ","
                + "\"growth\":" + growth + ","
                + "\"economy\":" + economy
                + "}";

            URL obj = new URL(url);
            HttpURLConnection con = (HttpURLConnection) obj.openConnection();

            con.setRequestMethod("POST");
            con.setRequestProperty("Content-Type", "application/json");
            con.setDoOutput(true);

            // send request
            OutputStream os = con.getOutputStream();
            os.write(json.getBytes("utf-8"));
            os.close();

            // read response
            BufferedReader br = new BufferedReader(
                new InputStreamReader(con.getInputStream(), "utf-8")
            );

            String response = "";
            String line;
            while ((line = br.readLine()) != null) {
                response += line;
            }

            // extract price_change
            int index = response.indexOf("price_change");
            if (index != -1) {
                String sub = response.substring(index);
                String value = sub.split(":")[1].replace("}", "").trim();
                return Double.parseDouble(value);
            }

            return 0;

        } catch (Exception e) {
            e.printStackTrace();
            return 0;
        }
    }
}]]></Text>
		</JavaClass>
	</JavaClasses>
