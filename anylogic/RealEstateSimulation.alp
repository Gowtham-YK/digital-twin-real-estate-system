				<Variable Class="Flow">
					<Id>1776920056353</Id>
					<Name><![CDATA[PriceChange]]></Name>
					<X>110</X><Y>50</Y>
					<Label><X>0</X><Y>-20</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TargetId="1776915304801" External="false" Constant="false" Array="false">
						<Formula><![CDATA[(time() % 5 == 0) 
? (
    APIConnector.callAPI(
        demand_factor,
        interest_rate,
        supply_factor,
        growth_rate,
        economic_growth
    )
    +
    (
        mode == 0
        ? 1000000 * (demand_factor - interest_rate - 0.5 * supply_factor + economic_growth)
        : 1000000 * (growth_rate + economic_growth)
    )
)
: 0]]></Formula>
						<Color>-4073239</Color>
						<ValveIndex>1</ValveIndex>
						<Points>
							<Point><X>0</X><Y>0</Y></Point>
							<Point><X>70</X><Y>0</Y></Point>
							<Point><X>220</X><Y>0</Y></Point>
						</Points>
